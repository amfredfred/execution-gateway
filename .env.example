# Runtime
NODE_ENV=development
PORT=4000
GATEWAY_PUBLIC_URL=http://localhost:4000
GATEWAY_CORS_ORIGIN=http://localhost:3000

# Shared Protocol v1 schemas
APEX_PROTOCOL_SCHEMA_DIR=../protocol/schemas

# Supabase - required when authentication and persistence are enabled
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Device authentication and token signing - generate strong secrets before use
DEVICE_JWT_SECRET=
DEVICE_JWT_TTL_SECONDS=900
ACTIVATION_KEY_PEPPER=
# Temporary configured license store. Replace with the Supabase repository.

# Private Signal Engine WebSocket authentication
SIGNAL_ENGINE_WS_URL=ws://localhost:8765
SIGNAL_ENGINE_WS_SECRET=
SIGNAL_ENGINE_RECONNECT_DELAY_MS=1000

# Released signal verification/signing
SIGNAL_SIGNING_PUBLIC_KEY=
SIGNAL_SIGNING_PRIVATE_KEY=

# Connection policy
ENGINE_HEARTBEAT_INTERVAL_SECONDS=30
ENGINE_OFFLINE_AFTER_SECONDS=90
MAX_ENGINE_CONNECTIONS=1000
ROOM_DEFAULT_TTL_SECONDS=3600
ROOM_EVICTION_INTERVAL_SECONDS=15

# Lemon Squeezy webhook signature verification
LEMON_SQUEEZY_WEBHOOK_SECRET=

# SMTP transactional email (activation key delivery)
# Leave SMTP_HOST blank to skip email and log keys to console only (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Apex Quant Trader <noreply@apexquanttrader.io>

# Public dashboard URL — embedded in activation key emails
DASHBOARD_URL=https://app.apexquanttrader.io

# Engine auto-updater — served by GET /engine-version
# Set these when you publish a new engine build to be auto-distributed
ENGINE_LATEST_VERSION=0.1.0
ENGINE_DOWNLOAD_URL=
ENGINE_DOWNLOAD_SHA256=
