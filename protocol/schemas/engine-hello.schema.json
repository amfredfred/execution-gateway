{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apexquantel.app/protocol/v1/engine-hello.schema.json",
  "title": "Engine Hello",
  "type": "object",
  "additionalProperties": false,
  "required": ["engine_id", "engine_version", "protocol_versions", "started_at", "accounts"],
  "properties": {
    "engine_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "engine_version": { "type": "string", "minLength": 1, "maxLength": 40 },
    "protocol_versions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["1.0"] }
    },
    "started_at": { "type": "string", "format": "date-time" },
    "accounts": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["login", "server", "mode"],
        "properties": {
          "login": { "type": "string", "minLength": 1, "maxLength": 40 },
          "server": { "type": "string", "minLength": 1, "maxLength": 120 },
          "mode": { "type": "string", "enum": ["demo", "live"] }
        }
      }
    },
    "device_credential":{ "type": "string", "minLength": 8, "maxLength": 128 }
  }
}
