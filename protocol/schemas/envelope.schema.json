{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apexquantel.app/protocol/v1/envelope.schema.json",
  "title": "Apex Quantel Protocol Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "message_id", "event", "sent_at", "payload"],
  "properties": {
    "protocol_version": { "const": "1.0" },
    "message_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "event": { "type": "string", "minLength": 3, "maxLength": 80 },
    "sent_at": { "type": "string", "format": "date-time" },
    "correlation_id": { "type": "string", "minLength": 8, "maxLength": 128 },
    "payload": { "type": "object" }
  }
}
